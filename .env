# Application
APP_NAME="FactureRapide API"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/factureRapide
DATABASE_URL_SYNC=postgresql+psycopg://postgres:postgres@localhost:5432/factureRapide

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# PDF Storage
PDF_STORAGE_PATH=./storage/invoices
PDF_RECEIPTS_PATH=./storage/receipts

# Email (optional - for sending invoices)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@facturerapide.com
INVOICE_EMAIL_SUBJECT=Facture {invoice_number} - {business_name}
QUOTE_EMAIL_SUBJECT=Devis {quote_number} - {business_name}
PAYMENT_EMAIL_SUBJECT=Reçu de paiement - Facture {invoice_number}
HTML_EMAIL_TEMPLATE=templates/email/invoice.html
TEXT_EMAIL_TEMPLATE=templates/email/invoice.txt
PAYMENT_REMINDER_HTML_TEMPLATE=templates/email/payment_reminder.html
PAYMENT_REMINDER_TEXT_TEMPLATE=templates/email/payment_reminder.txt 
